# SongCloud API Configuration (Production)

# Secret key required for all /api/* routes. If empty, routes are public.
SONGCLOUD_API_KEY=your_secret_api_key_here

# Restrict CORS to specific origin (e.g. https://yourapp.com). Use * for all.
SONGCLOUD_CORS_ORIGIN=*

# Optional: Spotify credentials for more stable playlist fetching
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Public origin for links
NEXT_PUBLIC_APP_ORIGIN=http://localhost:8086
